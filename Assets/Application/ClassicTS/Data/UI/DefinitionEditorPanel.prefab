using UnityEngine;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Numerics;
using Random = UnityEngine.Random;

namespace MassiveHadronLtd.IDs.HTB50
{
	/// <summary>
	/// Tester for RadixHash collision behavior and distribution.
	/// Generates unique input strings → hashes to [0, modulus-1]
	/// Tracks actual colliding pairs (birthday-paradox style)
	/// Reports observed vs expected collisions, bucket stats.
	/// </summary>
	public class RadixHashTester : MonoBehaviour
	{
		[Header("Initial Settings (can be changed at runtime)")]
		public int hashTestsTarget = 200000;
		public int fixedLengthToTest = 6;  // Affects modulus = radix^length

		[Header("GUI Style")]
		public int labelFontSize = 16;
		public int buttonHeight = 40;
		public int spacing = 8;

		// Runtime state
		private bool isRunning = false;
		private bool pauseRequested = false;

		private int currentBatch = 0;
		private long totalHashes = 0;
		private long totalCollidingPairs = 0;     // ← now counts actual pairs

		private Dictionary<BigInteger, List<string>> hashToInputs = new();
		private Dictionary<BigInteger, int> bucketCounts = new();

		private System.Diagnostics.Stopwatch stopwatch = new();

		private int hashDone = 0;
		private string statusMessage = "Ready";

		private BigInteger currentModulus;
		private readonly int radix = HTB50.Radix;

		void Start()
		{
			Debug.Log($"RadixHash Tester attached to {gameObject.name}");
			Debug.Log("Use GUI to start/pause/stop. Can run for hours.");
			UpdateModulus();
		}

		void UpdateModulus()
		{
			currentModulus = BigInteger.Pow(radix, fixedLengthToTest);
		}

		void Update()
		{
			if (!isRunning || pauseRequested) return;

			int chunkSize = Mathf.Min(5000, hashTestsTarget - hashDone);
			if (chunkSize > 0)
			{
				RunHashChunk(chunkSize);
				hashDone += chunkSize;
			}
			else
			{
				FinishBatch();
			}
		}

		void OnGUI()
		{
			GUI.skin.label.fontSize = labelFontSize;
			GUI.skin.button.fontSize = labelFontSize - 2;

			float y = 20;
			float w = Screen.width * 0.9f;
			float x = Screen.width * 0.05f;

			GUI.Label(new Rect(x, y, w, 40), "RadixHash Tester", new GUIStyle(GUI.skin.label) { fontStyle = FontStyle.Bold, fontSize = 22 });
			y += 50;

			GUI.Label(new Rect(x, y, w, 30), $"Status: {statusMessage}", new GUIStyle(GUI.skin.label) { normal = { textColor = Color.cyan } });
			y += 40;

			GUI.Label(new Rect(x, y, w, 25), $"Batches: {currentBatch}");
			y += 30;
			float pairRate = totalHashes > 0 ? (totalCollidingPairs * 100f / totalHashes) : 0f;
			GUI.Label(new Rect(x, y, w, 25), $"Total hashes: {totalHashes:N0}   Colliding pairs: {totalCollidingPairs:N0} ({pairRate:F4}%)");
			y += 30;
			GUI.Label(new Rect(x, y, w, 25), $"Unique buckets: {bucketCounts.Count:N0} / {currentModulus:N0}");
			y += 40;

			if (isRunning)
			{
				float prog = (float)hashDone / hashTestsTarget;
				GUI.Label(new Rect(x, y, w, 25), $"Batch progress: {(prog * 100):F1}%");
				GUI.HorizontalScrollbar(new Rect(x, y + 25, w, 20), 0, prog, 0, 1);
				y += 60;
			}

			if (!isRunning)
			{
				if (GUI.Button(new Rect(x, y, 180, buttonHeight), "Start Testing"))
				{
					StartTesting();
				}
			}
			else
			{
				if (GUI.Button(new Rect(x, y, 180, buttonHeight), pauseRequested ? "Resume" : "Pause"))
				{
					pauseRequested = !pauseRequested;
					statusMessage = pauseRequested ? "PAUSED" : "Running...";
				}

				if (GUI.Button(new Rect(x + 200, y, 180, buttonHeight), "Stop & Reset"))
				{
					ResetTester();
				}
			}

			y += buttonHeight + spacing;

			if (!isRunning || hashDone == 0)
			{
				if (GUI.Button(new Rect(x, y, 260, buttonHeight), "Run One Batch Now"))
				{
					StartSingleBatch();
				}
			}

			y += buttonHeight + spacing + 10;

			GUI.Label(new Rect(x, y, 220, 30), "Hashes / batch:");
			hashTestsTarget = (int)GUI.HorizontalSlider(new Rect(x + 230, y, 200, 30),
				hashTestsTarget, 10000, 2000000);
			GUI.Label(new Rect(x + 440, y, 100, 30), hashTestsTarget.ToString("N0"));
			y += 40;

			GUI.Label(new Rect(x, y, 220, 30), "Fixed length:");
			int newLen = (int)GUI.HorizontalSlider(new Rect(x + 230, y, 200, 30),
				fixedLengthToTest, 2, 12);
			if (newLen != fixedLengthToTest)
			{
				fixedLengthToTest = newLen;
				UpdateModulus();
			}
			GUI.Label(new Rect(x + 440, y, 100, 30), fixedLengthToTest.ToString());
			y += 50;

			GUI.Label(new Rect(x, y, w, 40), "Results & collision details in Console", new GUIStyle(GUI.skin.label) { normal = { textColor = new Color(0.9f, 0.9f, 0.6f) } });
		}

		private void StartTesting()
		{
			ResetTester(false);
			isRunning = true;
			pauseRequested = false;
			statusMessage = "Starting continuous testing...";
			stopwatch.Start();
			StartNewBatch();
		}

		private void StartSingleBatch()
		{
			if (isRunning) return;
			ResetTester(false);
			isRunning = true;
			pauseRequested = false;
			statusMessage = "Running one batch...";
			stopwatch.Start();
			StartNewBatch();
		}

		private void ResetTester(bool log = true)
		{
			isRunning = false;
			pauseRequested = false;
			currentBatch = 0;
			totalHashes = 0;
			totalCollidingPairs = 0;
			hashToInputs.Clear();
			bucketCounts.Clear();
			hashDone = 0;
			stopwatch.Reset();
			statusMessage = "Ready (reset)";
			if (log) Debug.Log("Tester reset.");
		}

		private void StartNewBatch()
		{
			currentBatch++;
			hashDone = 0;
			hashToInputs.Clear();
			bucketCounts.Clear();
			Debug.Log($"\n════ Batch #{currentBatch} started  {stopwatch.Elapsed.TotalSeconds:F1} s ════");
			statusMessage = $"Batch {currentBatch} – 0 / {hashTestsTarget:N0}";
		}

		private void FinishBatch()
		{
			Debug.Log($"Batch #{currentBatch} completed in {stopwatch.Elapsed.TotalSeconds:F1} s");

			PrintBatchSummary();

			if (Input.GetKey(KeyCode.LeftShift) || Input.GetKey(KeyCode.RightShift))
			{
				isRunning = false;
				statusMessage = $"Batch {currentBatch} finished (Shift held)";
				Debug.Log("Stopped after batch (Shift held)");
			}
			else if (isRunning)
			{
				StartNewBatch();
			}
			else
			{
				statusMessage = "Finished";
			}
		}

		private void RunHashChunk(int count)
		{
			var rng = new System.Random(currentBatch * 10007 + 65521);  // good prime seeds

			for (int i = 0; i < count; i++)
			{
				string input = GenerateUniqueTestString(rng, hashDone + i);

				BigInteger h = RadixHash.HashToRange(input, currentModulus);

				bucketCounts.TryGetValue(h, out int cnt);
				bucketCounts[h] = cnt + 1;

				if (!hashToInputs.TryGetValue(h, out var inputs))
				{
					inputs = new List<string>(4);  // small initial capacity
					hashToInputs[h] = inputs;
				}

				int prevCount = inputs.Count;
				inputs.Add(input);

				// Each new item creates 'prevCount' new colliding pairs
				if (prevCount > 0)
				{
					totalCollidingPairs += prevCount;

					if (totalCollidingPairs <= 20)  // log only first few examples
					{
						Debug.LogWarning($"Colliding pair #{totalCollidingPairs} for hash {h}: \"{inputs[^2]}\" ↔ \"{input}\"");
					}
				}
			}

			totalHashes += count;
			statusMessage = $"Batch {currentBatch} – {hashDone + count:N0} / {hashTestsTarget:N0}";
		}

		private string GenerateUniqueTestString(System.Random rng, int index)
		{
			var sb = new StringBuilder(64);
			sb.Append(index.ToString("D8")).Append('-');

			int style = rng.Next(9);
			switch (style)
			{
				case 0: sb.Append("u/").Append(rng.Next(1000000, 9999999)); break;
				case 1: sb.Append("prod-").Append(Guid.NewGuid().ToString("N").Substring(0, 12)); break;
				case 2: sb.Append("file/2026/").Append(new string('x', rng.Next(4, 30))); break;
				case 3: sb.Append("order#").Append(DateTime.UtcNow.Ticks).Append("-").Append(rng.Next(9999)); break;
				case 4: sb.Append("test.").Append(new string('a', rng.Next(6, 25))); break;
				case 5: sb.Append("Lorem ipsum ").Append(rng.Next(10000000)); break;
				case 6: sb.Append("user.").Append(rng.Next(1000, 999999).ToString("D6")).Append("@example.net"); break;
				case 7: sb.Append("img-").Append(rng.NextDouble().ToString("F10")); break;
				default: sb.Append("rand-").Append(BitConverter.ToString(Guid.NewGuid().ToByteArray()).Replace("-", "")); break;
			}
			return sb.ToString();
		}

		private void PrintBatchSummary()
		{
			Debug.Log($"──── Batch #{currentBatch} Summary ────");
			Debug.Log($"Hashes:                 {hashTestsTarget:N0}");
			Debug.Log($"Length:                 {fixedLengthToTest} chars (modulus = {currentModulus:N0})");
			Debug.Log($"Colliding pairs:        {totalCollidingPairs:N0}");

			if (bucketCounts.Count > 0)
			{
				var sizes = bucketCounts.Values;
				int max = sizes.Max();
				int min = sizes.Min();
				double avg = (double)totalHashes / bucketCounts.Count;

				Debug.Log($"Buckets used:           {bucketCounts.Count:N0} / {currentModulus:N0}");
				Debug.Log($"Max bucket occupancy:   {max}");
				Debug.Log($"Min bucket occupancy:   {min}");
				Debug.Log($"Average occupancy:      {avg:F3}");

				double expectedPairs = (double)totalHashes * (totalHashes - 1) / (2.0 * (double)currentModulus);
				Debug.Log($"Expected colliding pairs (birthday approx): {expectedPairs:F1}");
			}

			Debug.Log($"Batch time:             {stopwatch.Elapsed.TotalSeconds:F1} s");
		}

		void OnDestroy()
		{
			Debug.Log("RadixHash Tester destroyed.");
			if (totalHashes > 0)
				PrintBatchSummary();
		}
	}
}



using UnityEngine;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Numerics;

namespace MassiveHadronLtd.IDs.HTB50
{
	public class RadixHashTester : MonoBehaviour
	{
		[Header("Settings")]
		public int hashesPerBatch = 1000000;
		public int fixedLength = 6;

		[Header("GUI")]
		public int labelFontSize = 16;
		public int buttonHeight = 40;
		public int spacing = 8;

		// State
		private bool isRunning = false;
		private bool paused = false;

		private int batchCount = 0;
		private long batchHashes = 0;
		private long batchPairs = 0;

		private Dictionary<BigInteger, int> bucketCounts = new();
		private Dictionary<BigInteger, int> collisionExamples = new(); // only for logging

		private System.Diagnostics.Stopwatch watch = new System.Diagnostics.Stopwatch();

		private int doneThisBatch = 0;
		private string status = "Ready";

		private BigInteger modulus;
		private readonly int radix = HTB50.Radix;

		void Start()
		{
			Debug.Log("RadixHash collision tester ready. Use GUI to control.");
			UpdateModulus();
		}

		void UpdateModulus()
		{
			modulus = BigInteger.Pow(radix, fixedLength);
		}

		void Update()
		{
			if (!isRunning || paused) return;

			int remaining = hashesPerBatch - doneThisBatch;
			if (remaining <= 0)
			{
				FinishBatch();
				return;
			}

			int take = Mathf.Min(5000, remaining);
			RunChunk(take);
			doneThisBatch += take;
		}

		void OnGUI()
		{
			GUI.skin.label.fontSize = labelFontSize;
			GUI.skin.button.fontSize = labelFontSize - 2;

			float y = 20, w = Screen.width * 0.9f, x = Screen.width * 0.05f;

			GUI.Label(new Rect(x, y, w, 40), "RadixHash Tester", new GUIStyle(GUI.skin.label) { fontStyle = FontStyle.Bold, fontSize = 22 });
			y += 50;

			GUI.Label(new Rect(x, y, w, 30), $"Status: {status}", new GUIStyle(GUI.skin.label) { normal = { textColor = Color.cyan } });
			y += 40;

			GUI.Label(new Rect(x, y, w, 25), $"Batch: {batchCount}   Hashes this batch: {doneThisBatch:N0} / {hashesPerBatch:N0}");
			y += 30;

			float pairRate = batchHashes > 0 ? (batchPairs * 100f / batchHashes) : 0f;
			GUI.Label(new Rect(x, y, w, 25), $"Pairs this batch: {batchPairs:N0}  ({pairRate:F4}%)");
			y += 25;

			GUI.Label(new Rect(x, y, w, 25), $"Buckets used: {bucketCounts.Count:N0} / {modulus:N0}");
			y += 40;

			if (isRunning)
			{
				float p = (float)doneThisBatch / hashesPerBatch;
				GUI.Label(new Rect(x, y, w, 25), $"Progress: {(p * 100):F1}%");
				GUI.HorizontalScrollbar(new Rect(x, y + 25, w, 20), 0, p, 0, 1);
				y += 60;
			}

			if (!isRunning)
			{
				if (GUI.Button(new Rect(x, y, 180, buttonHeight), "Start"))
				{
					StartRun();
				}
			}
			else
			{
				if (GUI.Button(new Rect(x, y, 180, buttonHeight), paused ? "Resume" : "Pause"))
				{
					paused = !paused;
					status = paused ? "PAUSED" : "Running";
				}

				if (GUI.Button(new Rect(x + 200, y, 180, buttonHeight), "Stop & Reset"))
				{
					Reset();
				}
			}

			y += buttonHeight + spacing;

			GUI.Label(new Rect(x, y, 220, 30), "Hashes per batch:");
			hashesPerBatch = (int)GUI.HorizontalSlider(new Rect(x + 230, y, 200, 30), hashesPerBatch, 10000, 5000000);
			GUI.Label(new Rect(x + 440, y, 100, 30), hashesPerBatch.ToString("N0"));
			y += 40;

			GUI.Label(new Rect(x, y, 220, 30), "Fixed length:");
			int nl = (int)GUI.HorizontalSlider(new Rect(x + 230, y, 200, 30), fixedLength, 2, 12);
			if (nl != fixedLength)
			{
				fixedLength = nl;
				UpdateModulus();
			}
			GUI.Label(new Rect(x + 440, y, 100, 30), fixedLength.ToString());
			y += 50;
		}

		private void StartRun()
		{
			Reset(false);
			isRunning = true;
			paused = false;
			status = "Starting...";
			watch.Start();
			NewBatch();
		}

		private void Reset(bool log = true)
		{
			isRunning = false;
			paused = false;
			batchCount = 0;
			batchHashes = 0;
			batchPairs = 0;
			bucketCounts.Clear();
			collisionExamples.Clear();
			doneThisBatch = 0;
			watch.Reset();
			status = "Ready";
			if (log) Debug.Log("Tester reset.");
		}

		private void NewBatch()
		{
			batchCount++;
			doneThisBatch = 0;
			batchHashes = 0;
			batchPairs = 0;
			bucketCounts.Clear();
			collisionExamples.Clear();

			Debug.Log($"\n════ Batch #{batchCount} started  {watch.Elapsed.TotalSeconds:F1} s ════");
			status = $"Batch {batchCount} – 0 / {hashesPerBatch:N0}";
		}

		private void FinishBatch()
		{
			Debug.Log($"Batch #{batchCount} finished in {watch.Elapsed.TotalSeconds:F1} s");

			PrintSummary();

			if (Input.GetKey(KeyCode.LeftShift) || Input.GetKey(KeyCode.RightShift))
			{
				isRunning = false;
				status = "Stopped (Shift held)";
				Debug.Log("Stopped (Shift held)");
			}
			else if (isRunning)
			{
				NewBatch();
			}
			else
			{
				status = "Finished";
			}
		}

		private void RunChunk(int count)
		{
			var rng = new System.Random(batchCount * 10007 + 65521);

			for (int i = 0; i < count; i++)
			{
				string input = GenerateInput(rng, doneThisBatch + i);
				BigInteger h = RadixHash.HashToRange(input, modulus);

				bucketCounts.TryGetValue(h, out int cnt);
				bucketCounts[h] = cnt + 1;

				// Count new pairs this item creates
				int newPairs = cnt;  // pairs with each existing item
				if (newPairs > 0)
				{
					batchPairs += newPairs;

					// Log only first few per batch
					if (collisionExamples.Count < 15 && !collisionExamples.ContainsKey(h))
					{
						collisionExamples[h] = cnt + 1;
						Debug.LogWarning($"Collision in batch {batchCount} – hash {h}: now {cnt + 1} items");
					}
				}
			}

			batchHashes += count;
			doneThisBatch += count;
			status = $"Batch {batchCount} – {doneThisBatch:N0} / {hashesPerBatch:N0}";
		}

		private string GenerateInput(System.Random rng, int index)
		{
			var sb = new StringBuilder(64);
			sb.Append(index.ToString("D7")).Append('-');

			int style = rng.Next(10);
			switch (style)
			{
				case 0: sb.Append("u/").Append(rng.Next(1000000, 9999999)); break;
				case 1: sb.Append("prod-").Append(Guid.NewGuid().ToString("N").Substring(0, 12)); break;
				case 2: sb.Append("file/2026/").Append(new string('x', rng.Next(5, 35))); break;
				case 3: sb.Append("order#").Append(DateTime.UtcNow.Ticks).Append("-").Append(rng.Next(9999)); break;
				case 4: sb.Append("test.").Append(new string('a', rng.Next(8, 30))); break;
				case 5: sb.Append("lorem ").Append(rng.Next(1000000, 9999999)); break;
				case 6: sb.Append("user.").Append(rng.Next(1000, 999999).ToString("D6")).Append("@ex.net"); break;
				case 7: sb.Append("img-").Append(rng.NextDouble().ToString("F9")); break;
				case 8: sb.Append("doc-").Append(BitConverter.ToString(Guid.NewGuid().ToByteArray()).Replace("-", "").Substring(0, 16)); break;
				default: sb.Append("rand-").Append(rng.NextDouble().ToString("F12")); break;
			}
			return sb.ToString();
		}

		private void PrintSummary()
		{
			Debug.Log($"──── Batch #{batchCount} Summary ────");
			Debug.Log($"Hashes:                 {hashesPerBatch:N0}");
			Debug.Log($"Length:                 {fixedLength} chars (modulus = {modulus:N0})");
			Debug.Log($"Colliding pairs:        {batchPairs:N0}");

			if (bucketCounts.Count > 0)
			{
				var sizes = bucketCounts.Values;
				int max = sizes.Max();
				int min = sizes.Min();
				double avg = (double)batchHashes / bucketCounts.Count;

				Debug.Log($"Buckets used:           {bucketCounts.Count:N0} / {modulus:N0}");
				Debug.Log($"Max bucket:             {max}");
				Debug.Log($"Min bucket:             {min}");
				Debug.Log($"Avg occupancy:          {avg:F4}");

				double expected = (double)batchHashes * (batchHashes - 1) / (2.0 * (double)modulus);
				Debug.Log($"Expected pairs (birthday): {expected:F1}");
			}

			Debug.Log($"Batch time:             {watch.Elapsed.TotalSeconds:F1} s");
		}

		void OnDestroy()
		{
			Debug.Log("Tester destroyed.");
			if (batchHashes > 0)
				PrintSummary();
		}
	}
}