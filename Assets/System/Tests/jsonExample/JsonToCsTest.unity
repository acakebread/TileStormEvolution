--- !u!114 &939026900
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 939026899}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9f5bf97d9e45d042ac9d859c577986b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  jsonInput: "{\r\n  \"Groups\": [\r\n    {\r\n      \"Items\": [\r\n        {\r\n         
    \"$type\": \"Document\",\r\n          \"DocumentIndex\": 0,\r\n          \"Title\":
    \"Test.cs\"\r\n        },\r\n        {\r\n          \"$type\": \"Bookmark\",\r\n         
    \"Name\": \"ST:1:0:{12345678-1234-1234-1234-1234567890ab}\"\r\n        }\r\n     
    ]\r\n    }\r\n  ]\r\n}"
  cSharpRepresentation: "using System.Collections.Generic;\nusing UnityEngine;\nusing
    System.Linq;\n\npublic class JsonDeserializationExample : MonoBehaviour\n{\n   
    void Start()\n    {\n        string jsonString = @\"{\n  \"\"Groups\"\": [\n   
    {\n      \"\"Items\"\": [\n        {\n          \"\"$type\"\": \"\"Document\"\",\n         
    \"\"DocumentIndex\"\": 0,\n          \"\"Title\"\": \"\"Test.cs\"\"\n       
    },\n        {\n          \"\"$type\"\": \"\"Bookmark\"\",\n          \"\"Name\"\":
    \"\"ST:1:0:{12345678-1234-1234-1234-1234567890ab}\"\"\n        }\n      ]\n   
    }\n  ]\n}\";\n        try\n        {\n            var data = JsonTocs.FromJson<Dictionary<string,
    object>>(jsonString);\n            if (data != null)\n            {\n               
    var template =         new\n        {\n          _Groups = new[] {          
    new\n          {\n            _Items = new[] {             new\n            {\n             
    __type = \"\",\n              _DocumentIndex = 0,\n              _Title = \"\"\n           
    } }\n          } }\n        };\n\n                var result =         new\n       
    {\n          _Groups =           (data.ContainsKey(\"Groups\") ? ((object[])data[\"Groups\"]).Select((item,
    i) =>\n          {\n            var subDict = (Dictionary<string, object>)item;\n           
    return new\n            {\n              _Items =             (subDict.ContainsKey(\"Items\")
    ? ((object[])subDict[\"Items\"]).Select((item, i) =>\n            {\n             
    var subDict = (Dictionary<string, object>)item;\n              return new\n             
    {\n                __type = subDict.ContainsKey(\"$type\") ? subDict[\"$type\"].ToString()
    : \"\",\n                _DocumentIndex = subDict.ContainsKey(\"DocumentIndex\")
    ? System.Convert.ToInt32(subDict[\"DocumentIndex\"]) : 0,\n                _Name
    = subDict.ContainsKey(\"Name\") ? subDict[\"Name\"].ToString() : \"\",\n               
    _Title = subDict.ContainsKey(\"Title\") ? subDict[\"Title\"].ToString() : \"\"\n             
    };\n            }).ToArray() : new[] { new { __type = \"\", _DocumentIndex =
    0, _Name = \"\", _Title = \"\" } })\n            };\n          }).ToArray() :
    new[] { new { _Items = new[] { new\n{\n  __type = \"\",\n  _DocumentIndex = 0,\n 
    _Title = \"\"\n} } } })\n        };\n\n                // Display deserialized
    values\n                if (result._Groups.Length > 0 && result._Groups[0]._Items.Length
    > 0 && result._Groups[0]._Items[0].__type != null) Debug.Log($\"Groups[0].Items[0].$type:
    {result._Groups[0]._Items[0].__type}\"); // Document\n                if (result._Groups.Length
    > 0 && result._Groups[0]._Items.Length > 0) Debug.Log($\"Groups[0].Items[0].DocumentIndex:
    {result._Groups[0]._Items[0]._DocumentIndex}\"); // 0\n                if (result._Groups.Length
    > 0 && result._Groups[0]._Items.Length > 0 && result._Groups[0]._Items[0]._Title
    != null) Debug.Log($\"Groups[0].Items[0].Title: {result._Groups[0]._Items[0]._Title}\");
    // Test.cs\n                if (result._Groups.Length > 0 && result._Groups[0]._Items.Length
    > 1 && result._Groups[0]._Items[1].__type != null) Debug.Log($\"Groups[0].Items[1].$type:
    {result._Groups[0]._Items[1].__type}\"); // Bookmark\n                if (result._Groups.Length
    > 0 && result._Groups[0]._Items.Length > 1 && result._Groups[0]._Items[1]._Name
    != null) Debug.Log($\"Groups[0].Items[1].Name: {result._Groups[0]._Items[1]._Name}\");
    // ST:1:0:{12345678-1234-1234-1234-1234567890ab}\n            }\n           
    else\n            {\n                Debug.LogError(\"Failed to deserialize JSON\");\n           
    }\n        }\n        catch (System.Exception e)\n        {\n            Debug.LogError($\"Deserialization
    error: {e.Message}\");\n        }\n    }\n}\n"
