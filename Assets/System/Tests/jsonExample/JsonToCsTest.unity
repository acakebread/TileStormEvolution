  cSharpRepresentation: "using System;\r\nusing System.Collections.Generic;\r\nusing
    UnityEngine;\r\nusing System.Linq;\r\n\r\npublic class JsonDeserializationExample
    : MonoBehaviour\r\n{\r\n    void Start()\r\n    {\r\n        string jsonString
    = @\"{ \"\"a\"\": { \"\"b\"\": { \"\"c\"\": \"\"e:\\\\fpp\"\" } } }\r\n       
    \";\r\n        try\r\n        {\r\n            var data = JsonTocs.FromJson<Dictionary<string,
    object>>(jsonString);\r\n            if (data != null)\r\n            {\r\n               
    var template = new\r\n                {\r\n                    _a = new\r\n                   
    {\r\n                        _b = new\r\n                        {\r\n                           
    _c = (object)null\r\n                        }\r\n                    }\r\n               
    };\r\n\r\n                var result = new\r\n                {\r\n                   
    _a = (data.ContainsKey(\"a\") && data[\"a\"] != null ? new\r\n                   
    {\r\n                        _b = (((Dictionary<string, object>)data[\"a\"]).ContainsKey(\"b\")
    && ((Dictionary<string, object>)data[\"a\"])[\"b\"] != null ? new\r\n                       
    {\r\n                            _c = (((Dictionary<string, object>)data[\"a\"]).ContainsKey(\"b\")
    && ((Dictionary<string, object>)((Dictionary<string, object>)data[\"a\"])[\"b\"]).ContainsKey(\"c\")
    ? ((Dictionary<string, object>)((Dictionary<string, object>)data[\"a\"])[\"b\"])[\"c\"]
    : (object)null)\r\n                        } : new\r\n                       
    {\r\n                            _c = (object)null\r\n                       
    })\r\n                    } : new\r\n                    {\r\n                       
    _b = new\r\n                        {\r\n                            _c = (object)null\r\n                       
    }\r\n                    })\r\n                };\r\n\r\n                // Display
    deserialized values\r\n                if (result._a != null && result._a._b
    != null && result._a._b._c != null) Debug.Log($\"a.b.c : { result._a._b._c }\");
    // e:\\\\pp\r\n            }\r\n            else\r\n            {\r\n               
    Debug.LogError(\"Failed to deserialize JSON\");\r\n            }\r\n        }\r\n       
    catch (System.Exception e)\r\n        {\r\n            Debug.LogError($\"Deserialization
    error: {e.Message}\");\r\n        }\r\n    }\r\n}\r\n\r\n"
